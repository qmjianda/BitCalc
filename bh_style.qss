QWidget {
    background-color: #ffffff;
    color:#000000
}

QPushButton#BHBit {
  border: 0;
  border-radius: 10%;
  font-size: 8;
}

QPushButton#BHBit:hover{
  background-color: #74b9ff;
}

QPushButton#BHBit:disabled{
  color:#b1b3b6;
  background-color: #ffffff;
}

QLabel#BHBit[light_color='enable'] {
  color: #3498db;
}

QLabel#BHDispHeader {
  color: #2f3542;
  font-size: 14px;
}
